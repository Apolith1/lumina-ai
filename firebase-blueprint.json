{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a user and the AI assistant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "messages": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "enum": ["user", "assistant"] },
              "content": { "type": "string" },
              "timestamp": { "type": "number" },
              "model": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "image", "video"] },
              "mediaUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "mode": { "type": "string" },
        "studyMode": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "messages", "createdAt", "updatedAt", "userId"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "A generated image or video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "type", "url", "prompt", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Stores all chat sessions."
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Stores generated media metadata."
    }
  }
}
