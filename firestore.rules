rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (string)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - createdAt: number (required)
    //
    // Collection: chats
    // Document ID: chatId (string)
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - messages: array of objects (required)
    //   - createdAt: number (required)
    //   - updatedAt: number (required)
    //   - mode: string
    //   - studyMode: boolean
    //   - userId: string (required, must match auth.uid)
    //
    // Collection: gallery
    // Document ID: itemId (string)
    // Fields:
    //   - id: string (required)
    //   - type: string (required)
    //   - url: string (required)
    //   - prompt: string (required)
    //   - timestamp: number (required)
    //   - userId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidChat(data) {
      return data.id is string && data.id.size() > 0 &&
             data.title is string && data.title.size() < 200 &&
             data.messages is list && data.messages.size() < 1000 &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.userId is string;
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string && data.createdAt is number;
    }

    function isValidGalleryItem(data) {
      return data.id is string && data.type in ['image', 'video'] && 
             data.url is string && data.prompt is string && 
             data.timestamp is number && data.userId is string;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "apulaith9@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /chats/{chatId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidChat(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidChat(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidGalleryItem(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
